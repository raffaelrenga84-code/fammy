@@ -0,0 +1,160 @@
+import type { VercelRequest, VercelResponse } from "@vercel/node";
+import { Pool } from "pg";
+
+const pool = new Pool({ connectionString: process.env.DATABASE_URL });
+
+function formatDateToICS(dt: Date) {
+  return dt.toISOString().replace(/[-:]/g, "").split(".")[0] + "Z";
+}
+
+function escapeICSText(s: string) {
+  return s.replace(/\\/g, "\\\\").replace(/;/g, "\\;").replace(/,/g, "\\,").replace(/\n/g, "\\n");
+}
+
+export default async function handler(req: VercelRequest, res: VercelResponse) {
+  const { token } = req.query as { token?: string };
+  if (!token) return res.status(400).send("Missing token");
+
+  const client = await pool.connect();
+  try {
+    const fam = await client.query("SELECT id, name FROM families WHERE ical_token = $1 LIMIT 1", [token]);
+    if (fam.rowCount === 0) return res.status(404).send("Not found");
+
+    const familyId = fam.rows[0].id;
+    const events = await client.query(
+      `SELECT id, title, description, starts_at, ends_at, location
+       FROM events WHERE family_id = $1 AND canceled = false ORDER BY starts_at`,
+      [familyId]
+    );
+
+    res.setHeader("Content-Type", "text/calendar; charset=utf-8");
+    res.setHeader("Cache-Control", "public, max-age=3600");
+
+    let ics = "";
+    ics += "BEGIN:VCALENDAR\r\n";
+    ics += "VERSION:2.0\r\n";
+    ics += `PRODID:-//Fammy//EN\r\n`;
+    ics += "CALSCALE:GREGORIAN\r\n";
+
+    for (const ev of events.rows) {
+      const uid = `fammy-${ev.id}@fammy.example`;
+      const dtstart = formatDateToICS(new Date(ev.starts_at));
+      const dtend = formatDateToICS(new Date(ev.ends_at || ev.starts_at));
+      ics += "BEGIN:VEVENT\r\n";
+      ics += `UID:${uid}\r\n`;
+      ics += `SUMMARY:${escapeICSText(ev.title)}\r\n`;
+      if (ev.description) ics += `DESCRIPTION:${escapeICSText(ev.description)}\r\n`;
+      if (ev.location) ics += `LOCATION:${escapeICSText(ev.location)}\r\n`;
+      ics += `DTSTART:${dtstart}\r\n`;
+      ics += `DTEND:${dtend}\r\n`;
+      ics += "BEGIN:VALARM\r\n";
+      ics += "TRIGGER:-PT30M\r\n";
+      ics += "ACTION:DISPLAY\r\n";
+      ics += "DESCRIPTION:Reminder\r\n";
+      ics += "END:VALARM\r\n";
+      ics += "END:VEVENT\r\n";
+    }
+
+    ics += "END:VCALENDAR\r\n";
+    res.status(200).send(ics);
+  } catch (err) {
+    console.error(err);
+    res.status(500).send("Server error");
+  } finally {
+    client.release();
+  }
+}
+
diff --git a/migrations/20260428_add_ical_token.sql b/migrations/20260428_add_ical_token.sql
new file mode 100644
index 0000000..3333333
--- /dev/null
+++ b/migrations/20260428_add_ical_token.sql
@@ -0,0 +1,6 @@
+-- Migration: add ical_token to families
+ALTER TABLE families
+ADD COLUMN IF NOT EXISTS ical_token text;
+
+-- Generate tokens for existing rows (Postgres pgcrypto)
+UPDATE families SET ical_token = gen_random_uuid()::text WHERE ical_token IS NULL;
+
